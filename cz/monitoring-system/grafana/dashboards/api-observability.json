{
  "uid": "api-observability",
  "title": "API observability",
  "tags": ["api", "blackbox", "prometheus", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "probe_scope",
        "type": "query",
        "label": "มุมมอง (probe_scope)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 1,
        "regex": "",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "options": [],
        "query": {
          "query": "label_values(probe_success{job=~\"api_probe.*\"}, probe_scope)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(probe_success{job=~\"api_probe.*\"}, probe_scope)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "สรุป: min(probe_success) ตามมุมมอง — 1 = ทุกเป้าผ่าน",
      "type": "stat",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "min by (probe_scope) (probe_success{job=~\"api_probe.*\", probe_scope=~\"$probe_scope\"})",
          "legendFormat": "{{probe_scope}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Probe success (1 = สำเร็จ)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=~\"api_probe.*\", probe_scope=~\"$probe_scope\"}",
          "legendFormat": "{{probe_scope}} | {{service}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Latency (วินาที)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{job=~\"api_probe.*\", probe_scope=~\"$probe_scope\"}",
          "legendFormat": "{{probe_scope}} | {{service}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 4,
      "title": "HTTP status code (0 = ต่อไม่ติด / timeout / TLS / DNS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_http_status_code{job=~\"api_probe.*\", probe_scope=~\"$probe_scope\"}",
          "legendFormat": "{{probe_scope}} | {{service}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "points", "showPoints": "always", "pointSize": 8 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "SSL หมดอายุ (เฉพาะ HTTPS — วินาทีจนถึง expiry, สูง = ยังเหลือนาน)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(probe_ssl_earliest_cert_expiry{job=~\"api_probe.*\", probe_scope=~\"$probe_scope\"} - time())",
          "legendFormat": "{{probe_scope}} | {{service}} {{route}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "HTTP errors จากแอป (Nest counter)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (api_kind, status) (rate(http_api_errors_total[5m]))",
          "legendFormat": "{{api_kind}} status={{status}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    }
  ],
  "annotations": { "list": [] }
}
