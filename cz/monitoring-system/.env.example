# คัดลอกเป็นไฟล์ `.env` แล้วใส่ค่าจริง (อย่า commit `.env`)
# Slack Incoming Webhook — ดูวิธีสร้างในขั้นตอนคู่มือ

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXXXXXXXXXXXXXXXXX

# URL ที่เปิด Grafana จากเครื่องคุณ (ใส่ในลิงก์ใน Slack) — ลิงก์ไปแดชบอร์ด /d/log-history-loki/... และ /d/api-observability/...
GRAFANA_ROOT_URL=http://localhost:3001

# URL Prometheus สำหรับลิงก์ใน Slack (เบราว์เซอร์ต้องเปิดได้ — ถ้า monitoring อยู่คนละเครื่องให้ใส่ IP/โดเมน)
PROMETHEUS_EXTERNAL_URL=http://localhost:9090

# โพรบ API แบบ "ลูกค้าเห็น":
#   - prometheus/targets/public-probes.json (รวม / org-wide)
#   - prometheus/targets/services/*.json (แยกทีมละไฟล์ — ดู README ในโฟลเดอร์ services)
#   - ตัวอย่างรูปแบบ: prometheus/targets/examples/public-probes.example.json
# ว่าง [] = ไม่โพรบ public (alert internal-vs-public จะไม่ยิงถ้าไม่มีเป้า public)
# Frontend บน Vite พอร์ตโฮสต์ (เช่น 5173) ไม่ได้อยู่ใน via_host probe — ใช้ internal_docker + URL production/staging ใน public-probes.json แทน
